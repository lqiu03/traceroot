{
  "name": "@traceroot/seed",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "seed": "dotenv -e ../../../.env -- tsx src/index.ts",
    "seed:reset": "dotenv -e ../../../.env -- tsx src/index.ts --reset",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clickhouse/client": "^1.10.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@prisma/client": "^5.22.0",
    "@traceroot/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.9",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite-node": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
